{
  "name": "cincoscribe-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "CincoScribe — free, open-source transcription and TTS desktop app",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:desktop",
    "dev:desktop": "npm run dev --workspace=packages/desktop",
    "dev:web": "npm run dev --workspace=packages/web",
    "build:desktop": "npm run build --workspace=packages/desktop",
    "build:web": "npm run build --workspace=packages/web",
    "build:ui": "npm run build --workspace=packages/ui"
  },
  "license": "MIT"
}