{
  "name": "@cincoscribe/desktop",
  "version": "0.1.0",
  "description": "CincoScribe Desktop — free, MIT, local-first transcription and TTS",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "@cincoscribe/core": "*",
    "@cincoscribe/ui": "*",
    "electron-log": "^5.4.4",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "43.0.0",
    "electron-builder": "^26.15.3"
  },
  "license": "MIT",
  "build": {
    "appId": "com.cincoscribe.desktop",
    "productName": "CincoScribe",
    "win": {
      "target": "nsis"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!backend/**/__pycache__/**",
      "!backend/**/*.pyc"
    ]
  }
}
