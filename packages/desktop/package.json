{
  "name": "@cincoscribe/desktop",
  "version": "0.1.0",
  "description": "CincoScribe Desktop — free, MIT, local-first transcription and TTS",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "electron-builder --publish never"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vinayakawac/CincoScribe.git"
  },
  "dependencies": {
    "@cincoscribe/core": "*",
    "@cincoscribe/ui": "*",
    "electron-log": "^5.4.4",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "43.0.0",
    "electron-builder": "25.1.8"
  },
  "license": "MIT",
  "build": {
    "appId": "com.cincoscribe.desktop",
    "productName": "CincoScribe",
    "publish": {
      "provider": "github",
      "owner": "vinayakawac",
      "repo": "CincoScribe"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": "LICENSE",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!.venv/**",
          "!**/.venv/**"
        ]
      }
    ],
    "files": [
      "**/*",
      "!backend/**",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}"
    ]
  }
}
